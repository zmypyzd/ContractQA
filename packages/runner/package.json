{
  "name": "@contractqa/runner",
  "version": "0.12.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./reporter": { "import": "./dist/reporter.js", "types": "./dist/reporter.d.ts" },
    "./http": { "import": "./dist/http.js", "types": "./dist/http.d.ts" }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run"
  },
  "dependencies": {
    "@contractqa/core": "workspace:*",
    "@contractqa/oracle": "workspace:*",
    "@contractqa/evidence": "workspace:*",
    "@contractqa/probes": "workspace:*",
    "yaml": "^2.6.1"
  },
  "peerDependencies": {
    "@playwright/test": "^1.49.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": { "optional": true }
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
