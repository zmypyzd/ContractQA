{
  "name": "@contractqa/adapters",
  "version": "0.8.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./public": {
      "import": "./dist/public.js",
      "types": "./dist/public.d.ts"
    }
  },
  "files": [
    "dist",
    "STABILITY.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run"
  },
  "dependencies": {
    "@contractqa/core": "workspace:*",
    "mongodb": "^7.2.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "mongodb-memory-server": "^11.1.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "mongodbMemoryServer": {
    "downloadDir": "./node_modules/.cache/mongodb-memory-server"
  }
}
