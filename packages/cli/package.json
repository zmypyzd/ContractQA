{
  "name": "contractqa",
  "version": "1.1.0-beta.1",
  "type": "module",
  "bin": {
    "contractqa": "./dist/bin/contractqa.js"
  },
  "main": "./dist/src/index.js",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
