# Development-only Supabase secrets. Copy to .env to use the stack.
# These are NOT production credentials — they only protect a local docker stack.

POSTGRES_PASSWORD=postgres-dev-only-do-not-reuse
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
# ANON_KEY and SERVICE_ROLE_KEY are JWTs signed with JWT_SECRET.
# Default tokens below are issued by Supabase's open-source local dev stack and are SAFE to commit
# because they only work against a JWT_SECRET that matches the one above.
